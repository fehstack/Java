package br.com.celular.teste;
public class IOS {

	private String aparelho;
	private int memoria;
	private int anoAparelho;
	
	
	public String getAparelho() {
		return aparelho;
	}
	public void setAparelho(String aparelho) {
		this.aparelho = aparelho;
	}
	public int getMemoria() {
		return memoria;
	}
	public void setMemoria(int memoria) {
		this.memoria = memoria;
	}
	public int getAnoAparelho() {
		return anoAparelho;
	}
	public void setAnoAparelho(int anoAparelho) {
		this.anoAparelho = anoAparelho;
	}
	
	public String atributos() {
		return "\nO nome do aparelho é " + getAparelho() +
				"\nO mesmo possui de memória " + getMemoria() + "GB" +
				"\nO seu lançamento foi em " + getAnoAparelho()
				;
	}
	
}


package br.com.celular.teste;

public class Iphone {

	public static void main(String[] args) {

		IOS celular = new IOS();
		
		celular.setAparelho("Iphone 12");
		celular.setMemoria(64);
		celular.setAnoAparelho(2020);
		
		System.out.println(celular.atributos());
		
		
	}

}

